# ============================================
# API & Database Configuration
# ============================================
DATABASE_URL=postgresql://user:password@localhost/chatdb
OPENAI_API_KEY=sk-your-api-key-here
MODEL_NAME=gpt-4
EMBEDDING_MODEL=text-embedding-3-small

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# For production (e.g., Azure Redis):
# REDIS_HOST=your-redis.redis.cache.windows.net
# REDIS_PORT=6379
# REDIS_PASSWORD=your-password-here
# REDIS_DB=0

# ============================================
# Semantic Caching Settings
# ============================================
# How long to keep cached responses (seconds)
SEMANTIC_CACHE_TTL=86400

# Similarity threshold (0-1) to use cached response
# 0.95 = 95% similar questions get cached answer
SEMANTIC_SIMILARITY_THRESHOLD=0.95

# ============================================
# Rate Limiting (Token Bucket Algorithm)
# ============================================
# Max requests allowed per tenant per window
RATE_LIMIT_REQUESTS=100

# Time window in seconds
RATE_LIMIT_WINDOW=60

# Max burst capacity (for spikes)
RATE_LIMIT_BURST=10

# ============================================
# Sliding Window Context Settings
# ============================================
# Number of recent messages to send to LLM
# (older messages will be summarized)
SLIDING_WINDOW_SIZE=10

# Auto-summarize conversation after N messages
SUMMARIZATION_THRESHOLD=50

# Max tokens for auto-generated summary
SUMMARY_MAX_TOKENS=500

# ============================================
# Environment
# ============================================
# development | staging | production
ENVIRONMENT=development

# Debug mode (verbose logging)
DEBUG=True
